  "http://www.w3.org/2002/07/owl#equivalentProperty" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#defined_by"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/P30P",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_ZonePercentage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature assesses the fraction of the number of realised zones and the maximum num- ber of potential zones. Strongly linear or highly uniform ROI volumes produce a low zone percentage"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/P6QZ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_SumEntropy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The entropy for the cross-diagonal probabilities"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/P9VJ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "MinorAxisLength"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The minor axis length of the ROI provides a measure of how fare the volume extends along the second largest axis. The minor axis length is twice the semi-axis length, determined using the second largest eigenvalue obtained by PCA on the point of the voxel centers"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/PBX1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "VolumeDensityAABB"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Volume density is the fraction of the ROI volume and a comparison volume. This feature is also called extent\nSee https://doi.org/10.1016/j.patcog.2008.08.011"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/PIPE",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/Z7IV"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/PVMT",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/Q2ZB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/SOBB"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/Q3CK",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Elongation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Elongation is the ratio between the major and minor axis lengths. Elongation is espressed as inversed ratio: 1 means completely not elongated (e.g. a sphere). Smaller values express greater elongation of the ROI volume"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/Q3RU",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/8QU8"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/Q4LE",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Mean"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The mean grey level from grey level distribution"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/Q5SK",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/V7MM"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/QCDE",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "NGTDM_Coarseness"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/IPET"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Grey level differences in coarse textures are generally small due to large-scale patterns. Summing differences gives an indication of the level of the spatial rate of change in intensity"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/QCFX",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Sphericity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Sphericity is a further measure to describe how sphere-like the volume is"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/QG58",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Percentile10"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The statistical 10th percentile of the grey level distribution"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/QP79",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "ReSegmentationParameters"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/CINW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Re-segmentation entails updating the ROI mask R based on certain corresponding voxel intensities. Re-segmentation may be performed to exclude voxels from a previously segmented ROI, and is performed after interpolation."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/QWB0",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_Autocorrelation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The autocorrelation compares all possible pixel pairs and reporting the likelihood that both will be bright as a function of the distance and direction of separation"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/R3ER",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "VolumeDensityCH"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The volume density convex hull is defined as the ration between the volume and the volume of the ROI mesh convex hull set. This feature is also called solidity. See also https://dx.doi.org/10.1016%2Fj.patcog.2008.08.011"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/R59B",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "AreaDensityAABB"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Area Density considers the ratio of the ROI surface area and the surface area of the axis-aligned bounding box enclosing the ROI mesh vertex set. See also https://doi.org/10.1016/j.radonc.2016.07.007"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/R5YN",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_GreyLevelNonUniformity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature assesses the distribution of runs over the grey values (Galloway, 1975). The feature value is low when runs are equally distributed along grey levels"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/R8DG",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_FirstMeasureOfInformationCorrelation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The IMC1 is related to the entropy of the images and gives information on how a pixel value is correlated to its neighbourod"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/RDD2",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "AreaDensityAEE"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The area density approximate enclosing elipsoide is defined as the ratio between the area and the surface of the elipsoide having as axes the 3 eigenvectors from PCA. The surface of the elipsoide is approximated using infinite series"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/REK0",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Grey Level Dependence Matrix (GLDM)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/ZOEY"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The neighbouring grey level dependence matrix (NGLDM) captures the coarseness of the overall texture and is rotationally invariant. Defined in https://doi.org/10.1016/0734-189X(83)90032-4"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/RNU0",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Volume"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The volume V is calculated from the ROI mesh as indicated in https://doi.org/10.1109/ICIP.2001.958278"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/S5ZE",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/BCE0"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SALO",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "InterquartileRange"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The interquartile range (IQR) is defined as P75 - P25, where P75 is the 75th percentile of the image matrix, and P25 is the 25th"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SKGS",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Compactness1"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The Compactness defines the deviation of the ROI volume from a perfect sphere. Compactness 1 is a measure of how compact, or sphere-like or sphere like the volume is"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SOBB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "PixelOperations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/KA7K"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This class includes all the filters which apply basic operations on one / multiple pixels of an image"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SODN",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_LowDependenceEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises low neighbouring grey level dependence counts"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SSX6",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/8QU8"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SUJT",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/1XL1"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SWZ1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "VolumeDensityMVEE"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The volume density minimum volume enclosing ellipsoid is the ratio between the volume and the minimum volume enclosing ellipsoid, calculated as in https://doi.org/10.1016/j.dam.2007.02.013"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/SXLW",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_RunLengthVariance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature estimates the variance in runs for run lengths"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/TDIC",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "MajorAxisLength"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The major axis length is defined as twice the semi-axis length, dtermined using the largest eigenvalue obtained by principal component analysis (PCA) on the point set of voxel centers"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/TF7R",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "DifferenceAverage"
  }, {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_DifferentAverage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/TL9H",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_LowGreyLevelCountEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Instead of low neighbouring grey level dependence counts, low grey levels are emphasised"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/TP0I",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Grey Level Run Length Matrix (GLRLM)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/ZOEY"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The Grey level run length matrix (GLRLM) like the grey level co-occurrence matrix, GLRLM also assesses the distribution of discretised grey levels in an image or in a stack of images. However, instead of assessing the combination of levels between neighbouring pixels or voxels, GLRLM assesses grey level run lengths. Run length counts the frequency of consecutive voxels with discretised grey level i along direction delta"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/TU9B",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_JointEntropy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "As defined in http://dx.doi.org/10.1109/TSMC.1973.4309314"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/UC1G",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "AffineTransformations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/KA7K"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This class includes all the filters which apply affine transformations (e.g. rotations) which can be applied to an image"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/UHIW",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Statistical"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/72T0"
  }, {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsFeatures"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The statistical features describe how grey levels within the region of interest (ROI) are distributed"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/UHZT",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "ButterworthFilter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/JCNR"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This filter applies a Butterworth digital algorithm to an image. It can be both a low-pass or high-pass filter. The cut-off frequency needs to be specified"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/UR99",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_JointVariance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Also called sum of squares as in http://dx.doi.org/10.1109/TSMC.1973.4309314"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/USB3",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/QP79"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/V0L6",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/V3SW",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_LowGreyLevelRunEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The LGLRE measures the distribution of low gray level values. The LGRE is high for the image with low gray level values"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/V7MM",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "TopologicalOperations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/KA7K"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This class includes all the filters which are used to resize an image. They can be used both to increase or reduce the dimensions"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/VB3A",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_ZoneSizeNonUniformityNormalised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This is a normalised version of the zone size non-uniformity feature"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/VTM2",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "InterpolationParameters"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/CINW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Interpolation algoriths determine the grey level values in the interpolation grid after interpolation of the original grid. Interpolation is commonly used for texture features, to isotropic voxel sizes to be rotationally invariant"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/W4KF",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_LongRunEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The LRE measures the distribution of long runs"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/W92Y",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_RunLengthNonUniformity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This features assesses the distribution of runs over the run lengths (Galloway, 1975). The feature value is low when runs are equally distributed along run lengths."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/WE59",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/V7MM"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/WF0Z",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_InverseDifferenceMoment"
  } ],
