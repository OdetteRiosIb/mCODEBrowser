}, {
  "@id" : "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16809",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Non-invasive method of demonstrating internal anatomy based on the principle that atomic nuclei in a strong magnetic field absorb pulses of radiofrequency energy and emit them as radiowaves which can be reconstructed into computerized images. The concept includes proton spin tomographic techniques."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://www.radlex.org/RID/RID10312"
  }, {
    "@value" : "http://www.radlex.org/RID/RID10312"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Magnetic Resonance Image (MRI)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LK99"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "http://www.radlex.org/RID/RID10312"
  } ]
}, {
  "@id" : "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16899",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Stage_Type_Value"
  }, {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#NCIt"
  } ]
}, {
  "@id" : "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17007",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "An imaging technique using compounds labelled with short-lived positron-emitting radionuclides (such as carbon-11, nitrogen-13, oxygen-15 and fluorine-18) to measure cell metabolism. It has been useful in the study of soft tissues such as cancer; cardiovascular system; and the brain. SPECT is closely related to PET, but uses isotopes with longer half-lives and resolution is lower."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://www.radlex.org/RID/RID10337"
  }, {
    "@value" : "http://www.radlex.org/RID/RID10337"
