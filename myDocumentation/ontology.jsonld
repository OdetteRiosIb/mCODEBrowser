  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature assesses the fraction of the number of realised runs and the maximum number of potential runs (Galloway, 1975). Strongly linear or highly uniform ROI volumes produce a low run percentage"
  } ]
