  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Maximum2DDiameterColumn"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Maximum 2D diameter (Column) is defined as the largest pairwise Euclidean distance between tumor surface voxels in the row-slice (usually the coronal) plane."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/5GN9",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_HighGreyLevelZoneEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Measures the distribution of the higher gray-level values, with a higher value indicating a greater proportion of higher gray-level values and size zones in the image"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/5QRC",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_SmallZoneEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises small zones"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/5RAI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_SmallZoneLowGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises runs in the upper left quadrant of the GLSZM, where small zone sizes and low grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/5SPA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_GreyLevelNonUniformityNormalised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This is the normalised version of the grey level non-uniformity feature"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/5ZWQ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "RootMeanSquare"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The square root of the arithmetic mean of the squares of the values"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/60VM",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_JointAverage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The grey level weigthed sum of joint probabilities"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/62GR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/1XL1"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/65HE",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "NGTDM_Contrast"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/IPET"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Contrast depends on the dynamic range of the grey levels as well as the spatial frequency of intensity changes"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/6BDE",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "VolumeDensityAEE"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The volume density approximate enclosing elipsoide is defined as the ratio between the volume and the volume of the elipsoide having as principal axes the eigenvenctors from the principal component analysis of the ROI"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/6HIB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/Z7IV"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/6SLW",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/6XV8",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_DependenceCountPercentage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature assesses the fraction of the number of realised neighbourhoods and the max- imum number of potential neighbourhoods. The feature may be omitted as it evaluates to 1 when complete neighbourhoods are not required, which is the case under our definition"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/6YIO",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UC1G"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/72T0",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Radiomics Features"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#Biomarkers"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Radiomics features are particular features which can be extracted from objects within an image (e.g. from a region of interest) and that can potentially present a prognostic value (e.g related to the survival probability of a patient)."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/7ACA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/QP79"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/7J51",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "LeastAxisLength"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The least axis is the the axis along which the object is least extended. The least axis is twice the semi-axis length, determined using the smallest eigenvalue obtained by PCA on the point set of voxel centers"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/7NFM",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_ClusterShade"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The cluster shade is a measure of the skewness of the matrix and it is believed to gauge the perceptual concepts of uniformity. When the cluster age is high the image is asymmetric"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/7T7F",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "AreaDensityCH"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The area density convex hull is defined as the ratio between  the area and the surface of the convex hull obtained by summing the sum of the area of the faces in the convex hull"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/7TET",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "CoefficientOfVariation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Coefficient of variation is the ratio between the standard deviation and the mean value"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/84IY",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Maximum"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The maximum intensity value"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/8CE5",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_GreyLevelVariance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature estimates the variance in runs for the grey levels"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/8DWT",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Percentile90"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The statistical 90th percentile of the grey level distribution"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/8QU8",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "DiscretizationParameters"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/CINW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Grey level discretisation or quantisation of the ROI is often required to make calculation of texture features tractable (Yip and Aerts, 2016)"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/8S9J",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_Dissimilarity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The dissimilarity feature describes the variation of grey levels pair in an image. Dissimilarity always ranges from 0 and 1. It has maximum values when the grey level of the reference and the neighbor pixel is at the extremes of the possibile grey levels in the the texture sample"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/8ZQL",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_AngularSecondMoment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "It represents the energy of the probability matrix. \nPlease note that this feature is also called Energy or Uniformity."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/99N0",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IntegratedIntensity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Integrated intensity is the average grey level multiplied by the volume. In the context of\n18F-FDG-PET, this feature is called total legion glycolysis. See also https://doi.org/10.1016/j.radonc.2011.10.014"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9LZ9",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9QMG",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_HighDependenceHighGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The high dependence high grey level emphasis feature emphasises neighbouring grey level dependence counts in the lower right quadrant of the NGLDM, where high dependence counts and high grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9S40",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "QuartileCoefficientOfDispersion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The quartile coefficient of dispersion is defined as the ratio between the difference of the 75 and 25 percentile divided by the sume of 75 and 25 percentile"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9SAK",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Grey Level Size Zone Matrix (GLSZM)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/ZOEY"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The grey level size zone matrix (GLSZM) counts the number of groups of connected voxels with a specific discretised grey level value and size as in https://doi.org/10.1109/TBME.2013.2284600. Voxels are con- nected if the neighbouring voxel has the same discretised grey level value"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9SCJ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "Pyradiomics"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Maximum2DDiameterRow"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Maximum 2D diameter (Row) is defined as the largest pairwise Euclidean distance between tumor surface voxels in the column-slice (usually the sagittal) plane."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9VWX",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "AbsoluteFiltering"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/JCNR"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This filter substitutes each original pixel value with its absolute value"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/9ZK5",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
