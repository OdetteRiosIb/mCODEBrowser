    "@id" : "http://www.radiomics.org/RO/IPET"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Textures with large changes in grey levels between neighbouring voxels are called busy"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NTRS",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_DifferenceEntropy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The entropy for the diagonal probabilities"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NV3D",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/VTM2"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NZ9F",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "SavitzkyGolayFilter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/JCNR"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This filter is also called also called digital smoothing polynomial filters or least-squares smoothing filter. It is used to \"smooth out\" a noisy signal whose frequency span (without noise) is large. This filter minimizes the least-squares error in fitting a polynomial to frames of noisy data"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/OAE7",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_HighGreyLevelCountEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The feature emphasises high grey levels"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/OEEB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_SumVariance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The variance for the cross-diagonal probabilities"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/OKJI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_DependenceCountNonUniformityNormalised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This is a normalised version of the dependence count non-uniformity feature"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/OKUW",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GaborFilter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/JCNR"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This filter applies a Gabor filter with a specified wavelength (in pixels) and orientation (in degrees)"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/OVBL",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_GreyLevelNonUniformityNormalised"
  }, {
    "@value" : "This is the normalised version of the grey level non-uniformity feature"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/OWOH",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "FeatureSpecificParameters"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/CINW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Container for parameters and computation methods used to derive features"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/P00006",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2002/07/owl#equivalentProperty" : [ {
    "@id" : "http://www.radlex.org/RID/Contains"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/P00009",
