  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Cancer Risk Assessment acts as a standardized container for storing and exchanging estimated risk values. Because specific risk methodologies vary drastically by cancer type (e.g., leukemias versus sarcomas), this profile leaves the exact \"method\" open to clinical interpretation, but strictly standardizes how that data is communicated."
  } ]
