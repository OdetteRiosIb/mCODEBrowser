  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This class is a container for most common image filters used to pre-process an image before feature extraction"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KCS2",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UC1G"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KE2A",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Skewness"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The skewness measures the degree of histogram of gray levels asymmetry around the central value"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KLMA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "CentreOfMassShift"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The distance between the ROI volume centroid and the intensity-weigthted ROI volume centroid measures the placement of high and low intensity regions within the volume"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KOBO",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/1XL1"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KQW7",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KRCK",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "SphericalDisproportion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Spherical disproportion is a measure to describe how sphere-like the volume is"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/L0JK",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Maximum3DDiameter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The maximum 3D diameter is the distance between the two most distant vertices in the ROI mesh vertices sets"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/LFYI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Grey Level Co Occurence Matrix (GLCM)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/ZOEY"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The grey level co-occurrence matrix (GLCM) is a matrix that expresses how combinations of discretised grey levels of neighbouring pixels, or voxels in a 3D volume, are distributed along one of the image directions. In a 3 dimensional approach to texture analysis, the direct neighbourhood of a voxel consists of the 26 directly neighbouring voxels. Thus, there are 13 unique direction vectors within a neighbourhood volume for distance"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/LIFZ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/LK99",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Form of imaging that depends on the way the image is produced"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "http://www.radlex.org/RID/RID1031"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Imaging Modality"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "http://www.radlex.org/RID/RID10311"
  } ]
}, {
