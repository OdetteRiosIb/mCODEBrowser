  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This is a normalised version of the grey level non-uniformity feature"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/YEKZ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "ApproximateVolume"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "In clinical practice, volumes are commonly determined by counting voxels. For volumes consisting of a large number of voxels (1000s), the differences between approximate volume and mesh-based volume are usually negligible. However for volumes with a low number of voxels (10s to 100s), approximate volume will overestimate volume compared to mesh-based volume. It is therefore only used as a reference feature, and not in the calculation of other morphological features."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/YH51",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_LargeZoneLowGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises runs in the upper right quadrant of the GLSZM, where large zone sizes and low grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/YP6L",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
