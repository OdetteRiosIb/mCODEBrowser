  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#ImageFeatureSpace"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The image filter space is a container for all the filters that can be applied during the computation of a feature"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/JJUI",
