  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/72T0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Morphological features describe geometric aspects of a region of interest (ROI), such as area and volume. Morphological features are based on ROI voxel representations of the volume."
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/HDEZ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "NGTDM_Complexity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/IPET"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Complex textures are non-uniform and rapid changes in grey levels are common"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/HJ9O",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_RunEntropy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/HTZT",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_ShortRunLowGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The SRLGLE measures the joint distribution of short runs and low gray level values. The SRLGE is high for the image with many short runs and lower gray level values"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/HW1V",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_SmallZoneHighGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises runs in the lower left quadrant of the GLSZM, where small zone sizes and high grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IAZD",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/1XL1"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IB1Z",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_InverseDifference"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "http://www.radiomics.org/RO/26200"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Inverse difference is a measure of homogeneity. Grey level co-occurrences with a large difference in levels are weighed less, thus lowering the total feature score. The feature score is maximal if all grey levels are the same"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IC23",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_RunLengthNonUniformityNormalised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This is the normalised version of the run length non-uniformity feature"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IJAQ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/OWOH"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IMOQ",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_HighDependenceEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises high neighbouring grey level dependence counts"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IPET",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Neighbourhood Grey Tone Difference Matrix (NGTDM)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/ZOEY"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The neighbourhood grey tone difference matrix (NGTDM) contains the sum of grey level differences of pixels/voxels with discretised grey level i and the average discretised grey level of neigh- bouring pixels/voxels within a distance d. See also https://doi.org/10.1109/21.44046"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IPH6",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Kurtosis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Kurtosis is a measure of how outlier-prone a distribution is. The kurtosis of the normal distribution is 3. Distributions that are more outlier-prone than the normal distribution have kurtosis greater than 3; distributions that are less outlier-prone have kurtosis less than 3"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IQYR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "AreaDensityOMBB"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The area density oriented bounding box is the ratio between the area and the surface area of the same bounding box as calculated for the VolumeDensityOMBB"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/ITBB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/1XL1"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IUBX",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "MeanFilter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/JCNR"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The mean filter works on a n x n subregion of the image. At each position the center pixel is replaced by the mean value"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IVPO",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLRLM_LongRunLowGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/TP0I"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises runs in the upper right quadrant of the GLRLM, where long run lengths and low grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/IZBZ",
