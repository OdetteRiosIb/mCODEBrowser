  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/JNSA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_GreyLevelNonUniformity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature assesses the distribution of zone counts over the grey values. The feature value is low when zone counts are equally distributed along grey levels"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/JQQR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/Z7IV"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/K15C",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/8QU8"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/KA7K",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Image Operations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
