  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/SOBB"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/J17V",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLSZM_LargeZoneHighGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/9SAK"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises runs in the lower right quadrant of the GLSZM, where large zone sizes and high grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/JA6D",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_LowDependenceHighGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises neighbouring grey level dependence counts in the lower left quadrant of the NGLDM, where low dependence counts and high grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/JCNR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Image Filter Space"
