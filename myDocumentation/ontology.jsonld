  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Measures the distribution of lower gray-level size zones, with a higher value indicating a greater proportion of lower gray-level values and size zones in the image"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/XSB8",
