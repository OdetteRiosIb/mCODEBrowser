    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Median absolute deviation is similar in concept to mean absolute deviation, but measures dispersion from the median instead of mean"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/N8CA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  }, {
    "@value" : "The energy is the square sum of all the gray levels associated to an image"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Energy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/UHIW"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NBZI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLDM_HighDependenceLowGreyLevelEmphasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/REK0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "This feature emphasises neighbouring grey level dependence counts in the lower left quadrant of the NGLDM, where high dependence counts and low grey levels are located"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NDRX",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_InverseDifferenceNormalised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Normalized inverse difference as suggested in https://doi.org/10.5589/m02-004"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NI2N",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GLCM_Correlation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/LFYI"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The correlation feature shows the linear dependence of gray level values in the cooccurence matrix"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NPT7",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "GearyMeasure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Geary’s C measures spatial autocorrelation. See also https://doi.org/10.2307%2F2986645"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/NQ30",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "NGTDM_Busyness"
