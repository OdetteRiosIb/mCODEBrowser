    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The flatness is the ratio of the major and the least axis lengths. The flatness is expressed as an inverse ratio: 1 completely not flat; smaller values express objects which are increasingly flatter"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/N365",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "MoranIndex"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.radiomics.org/RO/HCUG"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Moran’s I index is an indicator of spatial autocorrelation. See also https://doi.org/10.1093/biomet/37.1-2.17"
  } ]
}, {
  "@id" : "http://www.radiomics.org/RO/N72L",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "IBSI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "MedianAbsoluteDeviation"
