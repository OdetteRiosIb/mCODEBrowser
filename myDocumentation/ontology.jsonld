}, {
  "@id" : "http://purl.bioontology.org/ontology/LNC/89247-1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Karnosfky Perfomance Status"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000335"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "http://snomed.info/id/273546003"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The Karnofsky Performance Status (KPS) is a tool used to measure a patient's functional status. It can be used to compare the effectiveness of different therapies and to help assess the prognosis of certain patients, such as those with certain cancers. The KPS score ranges from 0 to 100 in intervals of 10. Higher scores are associated with better functional status, with 100 representing no symptoms or evidence of disease, and 0 representing death."
  } ]
}, {
  "@id" : "http://purl.bioontology.org/ontology/LNC/89262-0",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ECOG Performance Status"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000335"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "http://snomed.info/id/424122007"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The Eastern Cooperative Oncology Group (ECOG) Performance Status represents the patient's functional status and is used to determine their ability to tolerate therapies in serious illness, specifically for chemotherapy."
  } ]
}, {
