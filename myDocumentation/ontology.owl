        <rdfs:label>Tumor Size Method</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000244 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000244">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261"/>
        <rdfs:label xml:lang="en">Cancer Stage</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000249 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000249">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000298"/>
        <rdfs:label xml:lang="en">Genomics Report</rdfs:label>
        <skos:definition>Structured summary of genomic testing results generated from a molecular diagnostic assay (e.g., NGS panel, whole-exome sequencing)..A genomics report details the analysis of an individual&apos;s DNA or RNA, identifying genetic variations and their clinical implications. It typically includes variant classifications, associated gene-disease risks, and personalized treatment or preventative recommendations.</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000256 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000256">
        <rdfs:label xml:lang="en">Report</rdfs:label>
        <skos:definition>An evidence-based document that presents, analyzes, and summarizes medical or scientific data</skos:definition>
        <skos:prefLabel>Report</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261">
        <rdfs:comment>Data structure used to transmit measurements, test results, and clinical assessments made about a patient</rdfs:comment>
        <rdfs:label xml:lang="en">Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000262 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000262">
        <rdfs:label xml:lang="en">Patient</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000265 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000265">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000335"/>
        <rdfs:label xml:lang="en">Lansky Play Performance Status</rdfs:label>
        <skos:definition>The Lansky Play-Performance Status for children is a parent-rated instrument which records usual play activity as the index of performance. It is similar to the Karnofsky Performance Scale for adults</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000266 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000266">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Therapeutic_Procedure"/>
        <rdfs:label xml:lang="en">Cancer-Related Medication Administration</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000267 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000267">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Intent"/>
        <rdfs:label xml:lang="en">Cancer-Related Medication Request</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000268 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000268">
        <rdfs:label xml:lang="en">Procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000270 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000270">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261"/>
        <rdfs:label xml:lang="en">Cancer Risk Assessment</rdfs:label>
        <skos:definition>Cancer Risk Assessment acts as a standardized container for storing and exchanging estimated risk values. Because specific risk methodologies vary drastically by cancer type (e.g., leukemias versus sarcomas), this profile leaves the exact &quot;method&quot; open to clinical interpretation, but strictly standardizes how that data is communicated.</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000273 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000273">
        <rdfs:label xml:lang="en">Body Structure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000274 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000274">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Finding"/>
        <rdfs:label xml:lang="en">Tumor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000275 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000275">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Treatment_Geometry"/>
        <rdfs:label xml:lang="en">Radiotherapy Volume</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000277 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000277">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000298"/>
        <rdfs:label xml:lang="en">Tumor Morphology</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000278 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000278">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000270"/>
        <rdfs:label xml:lang="en">Rhabdomyosarcoma Risk Assessment</rdfs:label>
        <skos:definition>Rhabdomyosarcoma (RMS) is defined by SNOMED CT under the hierarchy of malignant neoplasms and disorders. While there is no single SNOMED code for a &quot;risk assessment,&quot; the concept is represented through standardized clinical criteria that measure tumor severity and prognosis.</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000279 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000279">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000270"/>
        <rdfs:label xml:lang="en">Risk assessment for acute lymphoblastic leukemia (ALL).</rdfs:label>
        <skos:definition>Standardized metrics for Risk assessment for Acute Lymphoblastic Leukemia (ALL)</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000283 -->


