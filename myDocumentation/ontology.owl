    </owl:Class>
    


    <!-- http://snomed.info/id/999000 -->


    <owl:Class rdf:about="http://snomed.info/id/999000">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Body_Site"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ACUI -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ACUI">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_Contrast</rdfs:label>
        <skos:definition>Contrast assesses grey level variations. It is defines as in https://doi.org/10.5589/m02-004</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/AE86 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/AE86">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_ClusterProminence</rdfs:label>
        <skos:definition>The cluster prominence is a measure of asymmetry. When the cluster prominence value is high, the image is less symmetric</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ALVM -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ALVM">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/BCE0 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/BCE0">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/KA7K"/>
        <rdfs:label>Scaling</rdfs:label>
        <skos:definition>This class includes all the filters which are used to resize an image. They can be used both to increase or reduce the dimensions</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/BQWJ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/BQWJ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Compactness2</rdfs:label>
        <skos:definition>Compactness 2 is anothere measure to describe how sphere-like the volume is</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/BRI8 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/BRI8">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>AreaDensityMVEE</rdfs:label>
        <skos:definition>The surface density minimum volume enclosing ellipsoid is defined as the ratio between the area and the surface of the eilpsoide as defined in feature VolumeDensityMVEE</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/BTW3 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/BTW3">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/BYLV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/BYLV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_GreyLevelVariance</rdfs:label>
        <skos:definition>This feature estimates the variance in zone counts for the grey levels</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/C0JK -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/C0JK">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>SurfaceArea</rdfs:label>
        <skos:definition>The surface area is calculated from the ROI mesh, by summing over the face area surfaces</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CAC8 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CAC8">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>RobustMeanAbsoluteDeviation</rdfs:label>
        <skos:definition>The mean absolute deviation feature may be influenced by outliers. To increase robustness, the set of grey levels can be restricted to those which lie closer to the center of the distribution.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CAS9 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CAS9">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_DependenceCountEnergy</rdfs:label>
        <skos:definition>Defined as second moment in Sun and Wee (1983)</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CH45 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CH45">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CINW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CINW">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#ImageFeatureSpace"/>
        <rdfs:label>Feature Parameter Space</rdfs:label>
        <skos:definition>The feature parameter space is defined as the space that includes all the possible radiomics computation methods that can be applied to certain radiomics features. Subclasses are: aggregation re-segmentation, interpolation, features specific parameters, discretization</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CMWE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CMWE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>LaplacianFilter</rdfs:label>
        <skos:definition>Convolutes with a laplacian kernel the original image</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CRAM -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CRAM">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/CTNF -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/CTNF">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>GaussianFilter</rdfs:label>
        <skos:definition>This filter applies a gaussian kernel with a pre-defined average value and variance to each pixel of an image It is used to blur image and remove details and noise</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/D3YU -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/D3YU">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_DifferenceVariance</rdfs:label>
        <skos:definition>The variance for the diagonal probabilities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/D5AR -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/D5AR">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/DG8W -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/DG8W">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_ClusterTendency</rdfs:label>
        <skos:definition>The cluster tendency indicates into how many clusters the gray levels present in the image can be classified</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/DNX2 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/DNX2">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_DependenceCountVariance</rdfs:label>
        <skos:definition>This feature estimates the variance in dependence counts for the different dependence counts possible</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/E8JP -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/E8JP">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_InverseVariance</rdfs:label>
        <skos:definition>The inverse variance feature measures how the gray tone differences are distributed in pair elements</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ECT3 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ECT3">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Variance</rdfs:label>
        <skos:definition>The variance from grey level distribution</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/EQ3F -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/EQ3F">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_LowDependenceLowGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises neighbouring grey level dependence counts in the upper left quad- rant of the NGLDM, where low dependence counts and low grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/EY9L -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/EY9L">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/VTM2"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/F8XY -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/F8XY">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>ColliageFilter</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/FCBV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/FCBV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_DependenceCountEntropy</rdfs:label>
        <skos:definition>The entropy for the dependence counts</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/FFWD -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/FFWD">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/FP8K -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/FP8K">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_GreyLevelNonUniformity</rdfs:label>
        <skos:definition>This feature assesses the distribution of neighbouring grey level dependence counts over the grey values. The feature value is low when dependence counts are equally distributed along grey levels</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/G3QZ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/G3QZ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_HighGreyLevelRunEmphasis</rdfs:label>
        <skos:definition>The HGLRE measures  the distribution of high gray level values. The HGRE is high for the image with highgray level values</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/G5MN -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/G5MN">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/G6RO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/G6RO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/KA7K"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/G9EV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/G9EV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/GD3A -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/GD3A">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_ShortRunHighGreyLevelEmphasis</rdfs:label>
        <skos:definition>The SRHGLE measures the joint distribution of short runs and high gray level values. The SRHGE is high for the image with many short runs and high gray level values</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/GU8N -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/GU8N">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_ZoneSizeEntropy</rdfs:label>
        <skos:definition>Entropy related to the zone sizes</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/GYBY -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/GYBY">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_JointMaximum</rdfs:label>
        <skos:definition>Probability corresponding to the most common grey level co-occurence in the GCLM</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/H53N -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/H53N">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/V7MM"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/HCUG -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/HCUG">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/72T0"/>
        <rdfs:label>Morphological</rdfs:label>
        <skos:definition>Morphological features describe geometric aspects of a region of interest (ROI), such as area and volume. Morphological features are based on ROI voxel representations of the volume.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/HDEZ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/HDEZ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/IPET"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>NGTDM_Complexity</rdfs:label>
        <skos:definition>Complex textures are non-uniform and rapid changes in grey levels are common</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/HJ9O -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/HJ9O">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_RunEntropy</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/HTZT -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/HTZT">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_ShortRunLowGreyLevelEmphasis</rdfs:label>
        <skos:definition>The SRLGLE measures the joint distribution of short runs and low gray level values. The SRLGE is high for the image with many short runs and lower gray level values</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/HW1V -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/HW1V">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_SmallZoneHighGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises runs in the lower left quadrant of the GLSZM, where small zone sizes and high grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IAZD -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IAZD">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IB1Z -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IB1Z">
        <owl:equivalentClass rdf:resource="http://www.radiomics.org/RO/26200"/>
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_InverseDifference</rdfs:label>
        <skos:definition>Inverse difference is a measure of homogeneity. Grey level co-occurrences with a large difference in levels are weighed less, thus lowering the total feature score. The feature score is maximal if all grey levels are the same</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IC23 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IC23">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_RunLengthNonUniformityNormalised</rdfs:label>
        <skos:definition>This is the normalised version of the run length non-uniformity feature</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IJAQ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IJAQ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IMOQ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IMOQ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_HighDependenceEmphasis</rdfs:label>
        <skos:definition>This feature emphasises high neighbouring grey level dependence counts</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IPET -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IPET">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/ZOEY"/>
        <rdfs:label>Neighbourhood Grey Tone Difference Matrix (NGTDM)</rdfs:label>
        <skos:definition>The neighbourhood grey tone difference matrix (NGTDM) contains the sum of grey level differences of pixels/voxels with discretised grey level i and the average discretised grey level of neigh- bouring pixels/voxels within a distance d. See also https://doi.org/10.1109/21.44046</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IPH6 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IPH6">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Kurtosis</rdfs:label>
        <skos:definition>Kurtosis is a measure of how outlier-prone a distribution is. The kurtosis of the normal distribution is 3. Distributions that are more outlier-prone than the normal distribution have kurtosis greater than 3; distributions that are less outlier-prone have kurtosis less than 3</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IQYR -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IQYR">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>AreaDensityOMBB</rdfs:label>
        <skos:definition>The area density oriented bounding box is the ratio between the area and the surface area of the same bounding box as calculated for the VolumeDensityOMBB</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ITBB -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ITBB">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IUBX -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IUBX">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>MeanFilter</rdfs:label>
        <skos:definition>The mean filter works on a n x n subregion of the image. At each position the center pixel is replaced by the mean value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IVPO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IVPO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_LongRunLowGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises runs in the upper right quadrant of the GLRLM, where long run lengths and low grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/IZBZ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/IZBZ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/SOBB"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/J17V -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/J17V">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_LargeZoneHighGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises runs in the lower right quadrant of the GLSZM, where large zone sizes and high grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/JA6D -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/JA6D">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_LowDependenceHighGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises neighbouring grey level dependence counts in the lower left quadrant of the NGLDM, where low dependence counts and high grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/JCNR -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/JCNR">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#ImageFeatureSpace"/>
        <rdfs:label>Image Filter Space</rdfs:label>
        <skos:definition>The image filter space is a container for all the filters that can be applied during the computation of a feature</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/JJUI -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/JJUI">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/JN9H -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/JN9H">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_SecondMeasureOfInformationCorrelation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/JNSA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/JNSA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_GreyLevelNonUniformity</rdfs:label>
        <skos:definition>This feature assesses the distribution of zone counts over the grey values. The feature value is low when zone counts are equally distributed along grey levels</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/JQQR -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/JQQR">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/Z7IV"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/K15C -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/K15C">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/8QU8"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KA7K -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KA7K">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#ImageFeatureSpace"/>
        <rdfs:label>Image Operations</rdfs:label>
        <skos:definition>This class is a container for most common image filters used to pre-process an image before feature extraction</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KCS2 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KCS2">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UC1G"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KE2A -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KE2A">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Skewness</rdfs:label>
        <skos:definition>The skewness measures the degree of histogram of gray levels asymmetry around the central value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KLMA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KLMA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>CentreOfMassShift</rdfs:label>
        <skos:definition>The distance between the ROI volume centroid and the intensity-weigthted ROI volume centroid measures the placement of high and low intensity regions within the volume</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KOBO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KOBO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KQW7 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KQW7">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/KRCK -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/KRCK">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>SphericalDisproportion</rdfs:label>
        <skos:definition>Spherical disproportion is a measure to describe how sphere-like the volume is</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/L0JK -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/L0JK">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Maximum3DDiameter</rdfs:label>
        <skos:definition>The maximum 3D diameter is the distance between the two most distant vertices in the ROI mesh vertices sets</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/LFYI -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/LFYI">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/ZOEY"/>
        <rdfs:label>Grey Level Co Occurence Matrix (GLCM)</rdfs:label>
        <skos:definition>The grey level co-occurrence matrix (GLCM) is a matrix that expresses how combinations of discretised grey levels of neighbouring pixels, or voxels in a 3D volume, are distributed along one of the image directions. In a 3 dimensional approach to texture analysis, the direct neighbourhood of a voxel consists of the 26 directly neighbouring voxels. Thus, there are 13 unique direction vectors within a neighbourhood volume for distance</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/LIFZ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/LIFZ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/LK99 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/LK99">
        <owl:equivalentClass rdf:resource="http://www.radlex.org/RID/RID10311"/>
        <rdfs:comment>Form of imaging that depends on the way the image is produced</rdfs:comment>
        <rdfs:isDefinedBy>http://www.radlex.org/RID/RID1031</rdfs:isDefinedBy>
        <rdfs:label>Imaging Modality</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/LMSW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/LMSW">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/MBXH -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/MBXH">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>MedianFilter</rdfs:label>
        <skos:definition>The median filter works on a n x n subregion of the image. At each position the center voxel is replaced by the median value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/MV00 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/MV00">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/8QU8"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/MV01 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/MV01">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/8QU8"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/MV8M -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/MV8M">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/N17B -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/N17B">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Flatness</rdfs:label>
        <skos:definition>The flatness is the ratio of the major and the least axis lengths. The flatness is expressed as an inverse ratio: 1 completely not flat; smaller values express objects which are increasingly flatter</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/N365 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/N365">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>MoranIndex</rdfs:label>
        <skos:definition>Moran’s I index is an indicator of spatial autocorrelation. See also https://doi.org/10.1093/biomet/37.1-2.17</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/N72L -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/N72L">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>MedianAbsoluteDeviation</rdfs:label>
        <skos:definition>Median absolute deviation is similar in concept to mean absolute deviation, but measures dispersion from the median instead of mean</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/N8CA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/N8CA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>The energy is the square sum of all the gray levels associated to an image</rdfs:isDefinedBy>
        <rdfs:label>Energy</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NBZI -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NBZI">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_HighDependenceLowGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises neighbouring grey level dependence counts in the lower left quadrant of the NGLDM, where high dependence counts and low grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NDRX -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NDRX">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_InverseDifferenceNormalised</rdfs:label>
        <skos:definition>Normalized inverse difference as suggested in https://doi.org/10.5589/m02-004</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NI2N -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NI2N">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_Correlation</rdfs:label>
        <skos:definition>The correlation feature shows the linear dependence of gray level values in the cooccurence matrix</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NPT7 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NPT7">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GearyMeasure</rdfs:label>
        <skos:definition>Geary’s C measures spatial autocorrelation. See also https://doi.org/10.2307%2F2986645</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NQ30 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NQ30">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/IPET"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>NGTDM_Busyness</rdfs:label>
        <skos:definition>Textures with large changes in grey levels between neighbouring voxels are called busy</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NTRS -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NTRS">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_DifferenceEntropy</rdfs:label>
        <skos:definition>The entropy for the diagonal probabilities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NV3D -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NV3D">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/VTM2"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/NZ9F -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/NZ9F">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>SavitzkyGolayFilter</rdfs:label>
        <skos:definition>This filter is also called also called digital smoothing polynomial filters or least-squares smoothing filter. It is used to &quot;smooth out&quot; a noisy signal whose frequency span (without noise) is large. This filter minimizes the least-squares error in fitting a polynomial to frames of noisy data</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/OAE7 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/OAE7">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_HighGreyLevelCountEmphasis</rdfs:label>
        <skos:definition>The feature emphasises high grey levels</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/OEEB -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/OEEB">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_SumVariance</rdfs:label>
        <skos:definition>The variance for the cross-diagonal probabilities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/OKJI -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/OKJI">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_DependenceCountNonUniformityNormalised</rdfs:label>
        <skos:definition>This is a normalised version of the dependence count non-uniformity feature</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/OKUW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/OKUW">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>GaborFilter</rdfs:label>
        <skos:definition>This filter applies a Gabor filter with a specified wavelength (in pixels) and orientation (in degrees)</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/OVBL -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/OVBL">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_GreyLevelNonUniformityNormalised</rdfs:label>
        <rdfs:label>This is the normalised version of the grey level non-uniformity feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/OWOH -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/OWOH">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/CINW"/>
        <rdfs:label>FeatureSpecificParameters</rdfs:label>
        <skos:definition>Container for parameters and computation methods used to derive features</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/P30P -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/P30P">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_ZonePercentage</rdfs:label>
        <skos:definition>This feature assesses the fraction of the number of realised zones and the maximum num- ber of potential zones. Strongly linear or highly uniform ROI volumes produce a low zone percentage</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/P6QZ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/P6QZ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_SumEntropy</rdfs:label>
        <skos:definition>The entropy for the cross-diagonal probabilities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/P9VJ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/P9VJ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>MinorAxisLength</rdfs:label>
        <skos:definition>The minor axis length of the ROI provides a measure of how fare the volume extends along the second largest axis. The minor axis length is twice the semi-axis length, determined using the second largest eigenvalue obtained by PCA on the point of the voxel centers</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/PBX1 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/PBX1">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>VolumeDensityAABB</rdfs:label>
        <skos:definition>Volume density is the fraction of the ROI volume and a comparison volume. This feature is also called extent
See https://doi.org/10.1016/j.patcog.2008.08.011</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/PIPE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/PIPE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/Z7IV"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/PVMT -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/PVMT">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Q2ZB -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Q2ZB">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/SOBB"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Q3CK -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Q3CK">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Elongation</rdfs:label>
        <skos:definition>Elongation is the ratio between the major and minor axis lengths. Elongation is espressed as inversed ratio: 1 means completely not elongated (e.g. a sphere). Smaller values express greater elongation of the ROI volume</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Q3RU -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Q3RU">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/8QU8"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Q4LE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Q4LE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Mean</rdfs:label>
        <skos:definition>The mean grey level from grey level distribution</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Q5SK -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Q5SK">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/V7MM"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/QCDE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/QCDE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/IPET"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>NGTDM_Coarseness</rdfs:label>
        <skos:definition>Grey level differences in coarse textures are generally small due to large-scale patterns. Summing differences gives an indication of the level of the spatial rate of change in intensity</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/QCFX -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/QCFX">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Sphericity</rdfs:label>
        <skos:definition>Sphericity is a further measure to describe how sphere-like the volume is</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/QG58 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/QG58">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Percentile10</rdfs:label>
        <skos:definition>The statistical 10th percentile of the grey level distribution</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/QP79 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/QP79">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/CINW"/>
        <rdfs:label>ReSegmentationParameters</rdfs:label>
        <skos:definition>Re-segmentation entails updating the ROI mask R based on certain corresponding voxel intensities. Re-segmentation may be performed to exclude voxels from a previously segmented ROI, and is performed after interpolation.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/QWB0 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/QWB0">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_Autocorrelation</rdfs:label>
        <skos:definition>The autocorrelation compares all possible pixel pairs and reporting the likelihood that both will be bright as a function of the distance and direction of separation</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/R3ER -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/R3ER">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>VolumeDensityCH</rdfs:label>
        <skos:definition>The volume density convex hull is defined as the ration between the volume and the volume of the ROI mesh convex hull set. This feature is also called solidity. See also https://dx.doi.org/10.1016%2Fj.patcog.2008.08.011</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/R59B -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/R59B">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>AreaDensityAABB</rdfs:label>
        <skos:definition>Area Density considers the ratio of the ROI surface area and the surface area of the axis-aligned bounding box enclosing the ROI mesh vertex set. See also https://doi.org/10.1016/j.radonc.2016.07.007</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/R5YN -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/R5YN">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_GreyLevelNonUniformity</rdfs:label>
        <skos:definition>This feature assesses the distribution of runs over the grey values (Galloway, 1975). The feature value is low when runs are equally distributed along grey levels</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/R8DG -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/R8DG">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_FirstMeasureOfInformationCorrelation</rdfs:label>
        <skos:definition>The IMC1 is related to the entropy of the images and gives information on how a pixel value is correlated to its neighbourod</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/RDD2 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/RDD2">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>AreaDensityAEE</rdfs:label>
        <skos:definition>The area density approximate enclosing elipsoide is defined as the ratio between the area and the surface of the elipsoide having as axes the 3 eigenvectors from PCA. The surface of the elipsoide is approximated using infinite series</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/REK0 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/REK0">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/ZOEY"/>
        <rdfs:label>Grey Level Dependence Matrix (GLDM)</rdfs:label>
        <skos:definition>The neighbouring grey level dependence matrix (NGLDM) captures the coarseness of the overall texture and is rotationally invariant. Defined in https://doi.org/10.1016/0734-189X(83)90032-4</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/RNU0 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/RNU0">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Volume</rdfs:label>
        <skos:definition>The volume V is calculated from the ROI mesh as indicated in https://doi.org/10.1109/ICIP.2001.958278</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/S5ZE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/S5ZE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SALO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SALO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>InterquartileRange</rdfs:label>
        <skos:definition>The interquartile range (IQR) is defined as P75 - P25, where P75 is the 75th percentile of the image matrix, and P25 is the 25th</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SKGS -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SKGS">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Compactness1</rdfs:label>
        <skos:definition>The Compactness defines the deviation of the ROI volume from a perfect sphere. Compactness 1 is a measure of how compact, or sphere-like or sphere like the volume is</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SOBB -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SOBB">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/KA7K"/>
        <rdfs:label>PixelOperations</rdfs:label>
        <skos:definition>This class includes all the filters which apply basic operations on one / multiple pixels of an image</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SODN -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SODN">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_LowDependenceEmphasis</rdfs:label>
        <skos:definition>This feature emphasises low neighbouring grey level dependence counts</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SSX6 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SSX6">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/8QU8"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SUJT -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SUJT">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SWZ1 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SWZ1">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>VolumeDensityMVEE</rdfs:label>
        <skos:definition>The volume density minimum volume enclosing ellipsoid is the ratio between the volume and the minimum volume enclosing ellipsoid, calculated as in https://doi.org/10.1016/j.dam.2007.02.013</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/SXLW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/SXLW">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_RunLengthVariance</rdfs:label>
        <skos:definition>This feature estimates the variance in runs for run lengths</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/TDIC -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/TDIC">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>MajorAxisLength</rdfs:label>
        <skos:definition>The major axis length is defined as twice the semi-axis length, dtermined using the largest eigenvalue obtained by principal component analysis (PCA) on the point set of voxel centers</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/TF7R -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/TF7R">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>DifferenceAverage</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_DifferentAverage</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/TL9H -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/TL9H">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_LowGreyLevelCountEmphasis</rdfs:label>
        <skos:definition>Instead of low neighbouring grey level dependence counts, low grey levels are emphasised</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/TP0I -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/TP0I">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/ZOEY"/>
        <rdfs:label>Grey Level Run Length Matrix (GLRLM)</rdfs:label>
        <skos:definition>The Grey level run length matrix (GLRLM) like the grey level co-occurrence matrix, GLRLM also assesses the distribution of discretised grey levels in an image or in a stack of images. However, instead of assessing the combination of levels between neighbouring pixels or voxels, GLRLM assesses grey level run lengths. Run length counts the frequency of consecutive voxels with discretised grey level i along direction delta</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/TU9B -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/TU9B">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_JointEntropy</rdfs:label>
        <skos:definition>As defined in http://dx.doi.org/10.1109/TSMC.1973.4309314</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/UC1G -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/UC1G">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/KA7K"/>
        <rdfs:label>AffineTransformations</rdfs:label>
        <skos:definition>This class includes all the filters which apply affine transformations (e.g. rotations) which can be applied to an image</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/UHIW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/UHIW">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/72T0"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsFeatures"/>
        <rdfs:label>Statistical</rdfs:label>
        <skos:definition>The statistical features describe how grey levels within the region of interest (ROI) are distributed</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/UHZT -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/UHZT">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>ButterworthFilter</rdfs:label>
        <skos:definition>This filter applies a Butterworth digital algorithm to an image. It can be both a low-pass or high-pass filter. The cut-off frequency needs to be specified</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/UR99 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/UR99">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_JointVariance</rdfs:label>
        <skos:definition>Also called sum of squares as in http://dx.doi.org/10.1109/TSMC.1973.4309314</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/USB3 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/USB3">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/QP79"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/V0L6 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/V0L6">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/V3SW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/V3SW">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_LowGreyLevelRunEmphasis</rdfs:label>
        <skos:definition>The LGLRE measures the distribution of low gray level values. The LGRE is high for the image with low gray level values</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/V7MM -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/V7MM">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/KA7K"/>
        <rdfs:label>TopologicalOperations</rdfs:label>
        <skos:definition>This class includes all the filters which are used to resize an image. They can be used both to increase or reduce the dimensions</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/VB3A -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/VB3A">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_ZoneSizeNonUniformityNormalised</rdfs:label>
        <skos:definition>This is a normalised version of the zone size non-uniformity feature</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/VTM2 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/VTM2">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/CINW"/>
        <rdfs:label>InterpolationParameters</rdfs:label>
        <skos:definition>Interpolation algoriths determine the grey level values in the interpolation grid after interpolation of the original grid. Interpolation is commonly used for texture features, to isotropic voxel sizes to be rotationally invariant</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/W4KF -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/W4KF">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_LongRunEmphasis</rdfs:label>
        <skos:definition>The LRE measures the distribution of long runs</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/W92Y -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/W92Y">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_RunLengthNonUniformity</rdfs:label>
        <skos:definition>This features assesses the distribution of runs over the run lengths (Galloway, 1975). The feature value is low when runs are equally distributed along run lengths.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/WE59 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/WE59">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/V7MM"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/WF0Z -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/WF0Z">
        <owl:equivalentClass rdf:resource="http://www.radiomics.org/RO/26201"/>
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_InverseDifferenceMoment</rdfs:label>
        <skos:definition>Same as the inverse difference feature, but with lower weigths for elements that are further from the diagonal</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/WJTJ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/WJTJ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/V7MM"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/WTMV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/WTMV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/X13G -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/X13G">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/VTM2"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/XMSY -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/XMSY">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_LowGreyLevelZoneEmphasis</rdfs:label>
        <skos:definition>Measures the distribution of lower gray-level size zones, with a higher value indicating a greater proportion of lower gray-level values and size zones in the image</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/XSB8 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/XSB8">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Y12H -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Y12H">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Median</rdfs:label>
        <skos:definition>The median intensity value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Y1RO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Y1RO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_GreyLevelNonUniformityNormalised</rdfs:label>
        <skos:definition>This is a normalised version of the grey level non-uniformity feature</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/YEKZ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/YEKZ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>ApproximateVolume</rdfs:label>
        <skos:definition>In clinical practice, volumes are commonly determined by counting voxels. For volumes consisting of a large number of voxels (1000s), the differences between approximate volume and mesh-based volume are usually negligible. However for volumes with a low number of voxels (10s to 100s), approximate volume will overestimate volume compared to mesh-based volume. It is therefore only used as a reference feature, and not in the calculation of other morphological features.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/YH51 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/YH51">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_LargeZoneLowGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises runs in the upper right quadrant of the GLSZM, where large zone sizes and low grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/YP6L -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/YP6L">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Z09F -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Z09F">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/BCE0"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Z7IV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Z7IV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/KA7K"/>
        <rdfs:label>MathOperations</rdfs:label>
        <skos:definition>This class includes all the filters which apply math operations between two / more different images</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/Z87G -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/Z87G">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_DependenceCountNonUniformity</rdfs:label>
        <skos:definition>This features assesses the distribution of neighbouring grey level dependence counts over the different dependence counts. The feature value is low when dependence counts are equally distributed</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ZGXS -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ZGXS">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_SumAverage</rdfs:label>
        <skos:definition>The average for the cross-diagonal probabilities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ZH1A -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ZH1A">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>VolumeDensityOMBB</rdfs:label>
        <skos:definition>The volume density oriented mimum bounding box is the ratio between the volume and the volume of the oriented mimum bounding box. . The oriented minimum bounding box of the ROI mesh vertex
set encloses the vertex set and has the smallest possible volume</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ZOEY -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ZOEY">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/72T0"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsFeatures"/>
        <rdfs:label>Textural</rdfs:label>
        <skos:definition>The textural features describe patterns or the spatial distribution of voxel intensities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ZS1T -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ZS1T">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/SOBB"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/ZW7Z -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/ZW7Z">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/0OW5 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/0OW5">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/1GSF -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/1GSF">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Minimum</rdfs:label>
        <skos:definition>The minimum intensity value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/1PFV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/1PFV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_GreyLevelVariance</rdfs:label>
        <skos:definition>This feature estimates the variance in dependence counts for the grey levels.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/1QCO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/1QCO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_InverseDifferenceMomentNormalised</rdfs:label>
        <skos:definition>Normalized version of the inverse difference moment, as suggested by https://doi.org/10.5589/m02-004</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/1X9X -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/1X9X">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/IPET"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>NGTDM_Strength</rdfs:label>
        <skos:definition>Feature defined in http://dx.doi.org/10.1371/journal.pone.0093600</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/1XL1 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/1XL1">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/CINW"/>
        <rdfs:label>AggregationParameters</rdfs:label>
        <skos:definition>Specifies how texture matrix are computed and aggregated</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/17X7 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/17X7">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/8QU8"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/2I2N -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/2I2N">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/VTM2"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/2IQV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/2IQV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/2OJQ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/2OJQ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>IntensityRange</rdfs:label>
        <skos:definition>The range of grey levels is the difference between the maximum and the minimum</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/2PR5 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/2PR5">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>SurfaceToVolumeRatio</rdfs:label>
        <skos:definition>The surface to volume ratio is the ratio between the Surface and the Volume</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/22OV -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/22OV">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_ShortRunEmphasis</rdfs:label>
        <skos:definition>The SRE measures the distribution of short runs. The SRE is highly dependent on the occurrence of short runs and it gives high value for fine texture the value of SRE is high</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/25C7 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/25C7">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Asphericity</rdfs:label>
        <skos:definition>Asphericity describes how much the ROI deviates from a perfect sphere</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/26200 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/26200">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/26201 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/26201">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/3IDG -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/3IDG">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/3KUM -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/3KUM">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_LongRunHighGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises runs in the lower right quadrant of the GLRLM, where long run lengths and high grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/3NSA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/3NSA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_ZoneSizeVariance</rdfs:label>
        <skos:definition>This feature estimates the variance in zone counts for the different zone sizes</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/3S2S -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/3S2S">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/3YWD -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/3YWD">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>RietsFilter</rdfs:label>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/4BEG -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/4BEG">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>WaveletFilter</rdfs:label>
        <skos:definition>This filter decomposes an image in wavelets. A wavelet series is a representation of a square-integrable (real- or complex-valued) function by a certain orthonormal series generated by a wavelet</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/4FUA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/4FUA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>MeanAbsoluteDeviation</rdfs:label>
        <skos:definition>The mean of the absolute deviations of all voxel intensities around the mean intensitity value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/4JP3 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/4JP3">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_ZoneSizeNonUniformity</rdfs:label>
        <skos:definition>This features assesses the distribution of zone counts over the different zone sizes. The feature value is low when zone counts are equally distributed along zone sizes</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/4S59 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/4S59">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>Pyradiomics</rdfs:isDefinedBy>
        <rdfs:label>Maximum2DDiameterSlice</rdfs:label>
        <skos:definition>Maximum 2D diameter (Slice) is defined as the largest pairwise Euclidean distance between tumor surface voxels in the row-column (generally the axial) plane.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/4S5Z -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/4S5Z">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/4YPT -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/4YPT">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/V7MM"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/48P8 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/48P8">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_LargeZoneEmphasis</rdfs:label>
        <skos:definition>This feature emphasises large zones</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/5ABU -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/5ABU">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>Pyradiomics</rdfs:isDefinedBy>
        <rdfs:label>Maximum2DDiameterColumn</rdfs:label>
        <skos:definition>Maximum 2D diameter (Column) is defined as the largest pairwise Euclidean distance between tumor surface voxels in the row-slice (usually the coronal) plane.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/5GN9 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/5GN9">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_HighGreyLevelZoneEmphasis</rdfs:label>
        <skos:definition>Measures the distribution of the higher gray-level values, with a higher value indicating a greater proportion of higher gray-level values and size zones in the image</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/5QRC -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/5QRC">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_SmallZoneEmphasis</rdfs:label>
        <skos:definition>This feature emphasises small zones</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/5RAI -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/5RAI">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/9SAK"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLSZM_SmallZoneLowGreyLevelEmphasis</rdfs:label>
        <skos:definition>This feature emphasises runs in the upper left quadrant of the GLSZM, where small zone sizes and low grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/5SPA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/5SPA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_GreyLevelNonUniformityNormalised</rdfs:label>
        <skos:definition>This is the normalised version of the grey level non-uniformity feature</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/5ZWQ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/5ZWQ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>RootMeanSquare</rdfs:label>
        <skos:definition>The square root of the arithmetic mean of the squares of the values</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/6BDE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/6BDE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>VolumeDensityAEE</rdfs:label>
        <skos:definition>The volume density approximate enclosing elipsoide is defined as the ratio between the volume and the volume of the elipsoide having as principal axes the eigenvenctors from the principal component analysis of the ROI</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/6HIB -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/6HIB">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/Z7IV"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/6SLW -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/6SLW">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/6XV8 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/6XV8">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_DependenceCountPercentage</rdfs:label>
        <skos:definition>This feature assesses the fraction of the number of realised neighbourhoods and the max- imum number of potential neighbourhoods. The feature may be omitted as it evaluates to 1 when complete neighbourhoods are not required, which is the case under our definition</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/6YIO -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/6YIO">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UC1G"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/60VM -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/60VM">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_JointAverage</rdfs:label>
        <skos:definition>The grey level weigthed sum of joint probabilities</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/62GR -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/62GR">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/1XL1"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/65HE -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/65HE">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/IPET"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>NGTDM_Contrast</rdfs:label>
        <skos:definition>Contrast depends on the dynamic range of the grey levels as well as the spatial frequency of intensity changes</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/7ACA -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/7ACA">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/QP79"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/7J51 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/7J51">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>LeastAxisLength</rdfs:label>
        <skos:definition>The least axis is the the axis along which the object is least extended. The least axis is twice the semi-axis length, determined using the smallest eigenvalue obtained by PCA on the point set of voxel centers</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/7NFM -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/7NFM">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_ClusterShade</rdfs:label>
        <skos:definition>The cluster shade is a measure of the skewness of the matrix and it is believed to gauge the perceptual concepts of uniformity. When the cluster age is high the image is asymmetric</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/7T7F -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/7T7F">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>AreaDensityCH</rdfs:label>
        <skos:definition>The area density convex hull is defined as the ratio between  the area and the surface of the convex hull obtained by summing the sum of the area of the faces in the convex hull</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/7TET -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/7TET">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>CoefficientOfVariation</rdfs:label>
        <skos:definition>Coefficient of variation is the ratio between the standard deviation and the mean value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/72T0 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/72T0">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Biomarkers"/>
        <rdfs:label>Radiomics Features</rdfs:label>
        <skos:definition>Radiomics features are particular features which can be extracted from objects within an image (e.g. from a region of interest) and that can potentially present a prognostic value (e.g related to the survival probability of a patient).</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/8CE5 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/8CE5">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_GreyLevelVariance</rdfs:label>
        <skos:definition>This feature estimates the variance in runs for the grey levels</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/8DWT -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/8DWT">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Percentile90</rdfs:label>
        <skos:definition>The statistical 90th percentile of the grey level distribution</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/8QU8 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/8QU8">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/CINW"/>
        <rdfs:label>DiscretizationParameters</rdfs:label>
        <skos:definition>Grey level discretisation or quantisation of the ROI is often required to make calculation of texture features tractable (Yip and Aerts, 2016)</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/8S9J -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/8S9J">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_Dissimilarity</rdfs:label>
        <skos:definition>The dissimilarity feature describes the variation of grey levels pair in an image. Dissimilarity always ranges from 0 and 1. It has maximum values when the grey level of the reference and the neighbor pixel is at the extremes of the possibile grey levels in the the texture sample</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/8ZQL -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/8ZQL">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LFYI"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLCM_AngularSecondMoment</rdfs:label>
        <skos:definition>It represents the energy of the probability matrix. 
Please note that this feature is also called Energy or Uniformity.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/84IY -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/84IY">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>Maximum</rdfs:label>
        <skos:definition>The maximum intensity value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9LZ9 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9LZ9">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/OWOH"/>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9QMG -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9QMG">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/REK0"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLDM_HighDependenceHighGreyLevelEmphasis</rdfs:label>
        <skos:definition>The high dependence high grey level emphasis feature emphasises neighbouring grey level dependence counts in the lower right quadrant of the NGLDM, where high dependence counts and high grey levels are located</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9S40 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9S40">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/UHIW"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>QuartileCoefficientOfDispersion</rdfs:label>
        <skos:definition>The quartile coefficient of dispersion is defined as the ratio between the difference of the 75 and 25 percentile divided by the sume of 75 and 25 percentile</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9SAK -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9SAK">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/ZOEY"/>
        <rdfs:label>Grey Level Size Zone Matrix (GLSZM)</rdfs:label>
        <skos:definition>The grey level size zone matrix (GLSZM) counts the number of groups of connected voxels with a specific discretised grey level value and size as in https://doi.org/10.1109/TBME.2013.2284600. Voxels are con- nected if the neighbouring voxel has the same discretised grey level value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9SCJ -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9SCJ">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>Pyradiomics</rdfs:isDefinedBy>
        <rdfs:label>Maximum2DDiameterRow</rdfs:label>
        <skos:definition>Maximum 2D diameter (Row) is defined as the largest pairwise Euclidean distance between tumor surface voxels in the column-slice (usually the sagittal) plane.</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9VWX -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9VWX">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/JCNR"/>
        <rdfs:label>AbsoluteFiltering</rdfs:label>
        <skos:definition>This filter substitutes each original pixel value with its absolute value</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/9ZK5 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/9ZK5">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/TP0I"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>GLRLM_RunPercentage</rdfs:label>
        <skos:definition>This feature assesses the fraction of the number of realised runs and the maximum number of potential runs (Galloway, 1975). Strongly linear or highly uniform ROI volumes produce a low run percentage</skos:definition>
    </owl:Class>
    


    <!-- http://www.radiomics.org/RO/99N0 -->


    <owl:Class rdf:about="http://www.radiomics.org/RO/99N0">
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/HCUG"/>
        <rdfs:isDefinedBy>IBSI</rdfs:isDefinedBy>
        <rdfs:label>IntegratedIntensity</rdfs:label>
        <skos:definition>Integrated intensity is the average grey level multiplied by the volume. In the context of
18F-FDG-PET, this feature is called total legion glycolysis. See also https://doi.org/10.1016/j.radonc.2011.10.014</skos:definition>
    </owl:Class>
    


    <!-- http://www.radlex.org/RID/RID10311 -->


    <owl:Class rdf:about="http://www.radlex.org/RID/RID10311">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#RadLex"/>
    </owl:Class>
    


    <!-- http://www.radlex.org/RID/RID10312 -->


    <owl:Class rdf:about="http://www.radlex.org/RID/RID10312"/>
    


    <!-- http://www.radlex.org/RID/RID10321 -->


    <owl:Class rdf:about="http://www.radlex.org/RID/RID10321"/>
    


    <!-- http://www.radlex.org/RID/RID10337 -->


    <owl:Class rdf:about="http://www.radlex.org/RID/RID10337"/>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Acquisition_Properties -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Acquisition_Properties">
        <rdfs:label>Acquisition Properties</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Anatomic_Descriptor -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Anatomic_Descriptor">
        <rdfs:label>Anatomic Descriptor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Biomarkers -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Biomarkers">
        <rdfs:label>Biomarkers</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Body_Site -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Body_Site">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000273"/>
        <rdfs:label>Body Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#CancerPatient -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#CancerPatient">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000262"/>
        <rdfs:isDefinedBy xml:lang="en">This class denotes the Cancer Patient Profile from mCODE STU4.</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cancer Patient</rdfs:label>
        <owl:versionInfo>STU4</owl:versionInfo>
        <skos:definition xml:lang="en">A patient who has been diagnosed with or is receiving medical treatment for a malignant growth or tumor.</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Risk_Assessment_Value -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Risk_Assessment_Value">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261"/>
        <rdfs:label>Cancer Risk Assessment Value</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Stage_Method -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Stage_Method">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000244"/>
        <rdfs:label>Cancer Staging Method</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Stage_Type_Value -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Stage_Type_Value">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000244"/>
        <RID:Definition>Codes that identify the kind of stage reported in an Observation, necessary to correctly interpret the value associated with a staging Observation. In terms of the SNOMED CT hierarchy, these codes represent observable entities. If the staging system used to determine the stage is not implicit in this code, the staging system must be separately recorded in Observation.method. More specific staging profiles, if available, should be consulted before determining the correct code.</RID:Definition>
        <rdfs:label>Cancer Stage Type Value</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Evidence -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Evidence">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Evidence_Type"/>
        <rdfs:label>Clinical Evidence</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Finding -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Finding">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000273"/>
        <rdfs:label>Clinical Finding</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Intent -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Intent">
        <rdfs:label>Clinical Intent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Measurement_Method -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Clinical_Measurement_Method">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000316"/>
        <rdfs:label>Clinical Measurement Method</rdfs:label>
        <skos:definition>In HL7, a clinical measurement method defines the specific technique, device, or procedure used to ascertain an observation (e.g., blood pressure measured via arterial puncture vs. automatic cuff).</skos:definition>
        <skos:definition>SNOMED CT deinifion: it specifies exactly how a clinical evaluation or observation procedure is performed</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#DiagnosticRadiomicsProfile -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#DiagnosticRadiomicsProfile">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#RadiomicsProfile"/>
        <rdfs:label xml:lang="en">Diagnostic Radiomics Report</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Disease_Status -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Disease_Status">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000261"/>
        <rdfs:label>Disease Status</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#DoseDistributionPlanAcquisitionProfile -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#DoseDistributionPlanAcquisitionProfile">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Acquisition_Properties"/>
        <rdfs:label>Dose Distribution Acquisition</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsFeatures -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsFeatures">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Biomarkers"/>
        <rdfs:label>Dosiomics Features</rdfs:label>
        <skos:definition>Advanced field of study in radiation therapy. Instead of looking at a medical image like an X-ray or MRI, dosiomics extracts high-dimensional, minable mathematical data directly from a patient&apos;s 3D radiation dose distributions.</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsProfile -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#DosiomicsProfile">
