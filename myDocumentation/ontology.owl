    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#Genomics -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#Genomics">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Biomarkers"/>
        <rdfs:label>Genomics</rdfs:label>
        <skos:definition>Any distinct, identifiable portion or characteristic of an organism&apos;s DNA. It can range in size from a complete chromosome down to a single base pair. In bioinformatics, features are the structural and functional components annotated on a genome&apos;s reference sequence.</skos:definition>
    </owl:Class>
    


