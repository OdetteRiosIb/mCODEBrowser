    <!-- http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16809 -->


    <owl:Class rdf:about="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16809">
        <owl:equivalentClass rdf:resource="http://www.radlex.org/RID/RID10312"/>
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LK99"/>
        <rdfs:comment>Non-invasive method of demonstrating internal anatomy based on the principle that atomic nuclei in a strong magnetic field absorb pulses of radiofrequency energy and emit them as radiowaves which can be reconstructed into computerized images. The concept includes proton spin tomographic techniques.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.radlex.org/RID/RID10312"/>
        <rdfs:isDefinedBy>http://www.radlex.org/RID/RID10312</rdfs:isDefinedBy>
        <rdfs:label>Magnetic Resonance Image (MRI)</rdfs:label>
    </owl:Class>
    


    <!-- http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16899 -->


    <owl:Class rdf:about="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16899">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#Cancer_Stage_Type_Value"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#NCIt"/>
    </owl:Class>
    


    <!-- http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17007 -->


    <owl:Class rdf:about="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17007">
        <owl:equivalentClass rdf:resource="http://www.radlex.org/RID/RID10337"/>
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LK99"/>
        <rdfs:comment>An imaging technique using compounds labelled with short-lived positron-emitting radionuclides (such as carbon-11, nitrogen-13, oxygen-15 and fluorine-18) to measure cell metabolism. It has been useful in the study of soft tissues such as cancer; cardiovascular system; and the brain. SPECT is closely related to PET, but uses isotopes with longer half-lives and resolution is lower.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.radlex.org/RID/RID10337"/>
        <rdfs:isDefinedBy>http://www.radlex.org/RID/RID10337</rdfs:isDefinedBy>
        <rdfs:label>Positron Emission Tomography (PET)</rdfs:label>
    </owl:Class>
    


    <!-- http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17204 -->


    <owl:Class rdf:about="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17204">
        <owl:equivalentClass rdf:resource="http://www.radlex.org/RID/RID10321"/>
        <rdfs:subClassOf rdf:resource="http://www.radiomics.org/RO/LK99"/>
        <rdfs:comment>Tomography using x-ray transmission and a computer algorithm to reconstruct the image.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.radlex.org/RID/RID10321"/>
        <rdfs:label>Computed Tomography (CT)</rdfs:label>
    </owl:Class>
    


