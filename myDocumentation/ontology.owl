        <skos:definition>An entity obtained (usually from a patient) for examination or analysis</skos:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000293 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000293">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000292"/>
        <rdfs:label xml:lang="en">Human Specimen</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000298 -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/mCODERadiomics#mCR_0000298">
