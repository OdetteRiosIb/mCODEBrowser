                                   rdfs:subClassOf <http://www.radiomics.org/RO/LFYI> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLCM_JointEntropy" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "As defined in http://dx.doi.org/10.1109/TSMC.1973.4309314" .


