                                   rdfs:subClassOf <http://www.radiomics.org/RO/REK0> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLDM_GreyLevelNonUniformity" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "This feature assesses the distribution of neighbouring grey level dependence counts over the grey values. The feature value is low when dependence counts are equally distributed along grey levels" .


