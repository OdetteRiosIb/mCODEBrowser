#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/so#contains
<http://purl.obolibrary.org/obo/so#contains> rdf:type owl:ObjectProperty ;
                                             owl:equivalentProperty <http://www.radiomics.org/RO/P00006> ,
                                                                    :mCR_0000254 .


###  http://purl.obolibrary.org/obo/so#has_part
<http://purl.obolibrary.org/obo/so#has_part> rdf:type owl:ObjectProperty ;
                                             owl:equivalentProperty <http://www.radlex.org/RID/Has_Part> .


###  http://www.radiomics.org/RO/P00006
<http://www.radiomics.org/RO/P00006> rdf:type owl:ObjectProperty ;
                                     owl:equivalentProperty <http://www.radlex.org/RID/Contains> .


###  http://www.radiomics.org/RO/P00009
<http://www.radiomics.org/RO/P00009> rdf:type owl:ObjectProperty ;
                                     owl:equivalentProperty :defined_by .


###  http://www.radlex.org/RID/Contains
<http://www.radlex.org/RID/Contains> rdf:type owl:ObjectProperty ;
                                     owl:equivalentProperty :mCR_0000254 .


###  http://www.radlex.org/RID/Has_Part
<http://www.radlex.org/RID/Has_Part> rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#AssessedWith
:AssessedWith rdf:type owl:ObjectProperty ;
              rdfs:range :Clinical_Measurement_Method ;
              rdfs:label "ssessed with" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#DiseaseStatusDependsOn
:DiseaseStatusDependsOn rdf:type owl:ObjectProperty ;
                        rdfs:domain :Disease_Status ;
                        rdfs:range :Evidence_Type ;
                        rdfs:label "disease status based on" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#LocatedIn
:LocatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :mCR_0000274 ;
           rdfs:label "located In" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#SampleCollectedFrom
:SampleCollectedFrom rdf:type owl:ObjectProperty ;
                     rdfs:domain :mCR_0000262 ;
                     rdfs:range <http://snomed.info/id/123038009> ,
                                :mCR_0000293 ;
                     rdfs:label "sample collected from" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#assessed_with
:assessed_with rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#based_on
:based_on rdf:type owl:ObjectProperty ;
          rdfs:domain :ImagingStudyProfile ;
          rdfs:range <http://www.radiomics.org/RO/LK99> .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#defined_by
:defined_by rdf:type owl:ObjectProperty ;
            owl:equivalentProperty :mCR_0000296 ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain <http://www.radiomics.org/RO/72T0> ,
                        :DosiomicsFeatures ;
            rdfs:range :ImageFeatureSpace ;
            rdfs:label "defined by" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#has
:has rdf:type owl:ObjectProperty ;
     rdfs:domain :CancerPatient ;
     rdfs:range :ImagingStudyProfile ;
     rdfs:label "undergoes an" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasEthnicity
:hasEthnicity rdf:type owl:ObjectProperty ;
              rdfs:domain :mCR_0000262 ;
              rdfs:range <http://snomed.info/id/372148003> ;
              rdfs:label "has ethnicity" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasGender
:hasGender rdf:type owl:ObjectProperty ;
           rdfs:domain :CancerPatient ;
           rdfs:range <http://snomed.info/id/365873007> ;
           rdfs:label "has gender" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasRace
:hasRace rdf:type owl:ObjectProperty ;
         rdfs:domain :mCR_0000262 ;
         rdfs:range <http://snomed.info/id/415229000> ;
         rdfs:label "has race" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasSpecimenCollectionSite
:hasSpecimenCollectionSite rdf:type owl:ObjectProperty ;
                           rdfs:domain :mCR_0000293 ;
                           rdfs:range :Body_Site ;
                           rdfs:label "taken from specimen collection site" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasTreatmentOutcome
:hasTreatmentOutcome rdf:type owl:ObjectProperty ;
                     rdfs:domain :CancerPatient ;
                     rdfs:range :Patient_Treatment_Outcome ;
                     rdfs:label "has treatment outcome" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#has_Disease_Status
:has_Disease_Status rdf:type owl:ObjectProperty ;
                    rdfs:domain :CancerPatient ,
