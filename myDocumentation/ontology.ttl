                                                            rdfs:subClassOf <http://www.radiomics.org/RO/LK99> ;
                                                            rdfs:comment "Tomography using x-ray transmission and a computer algorithm to reconstruct the image." ;
                                                            rdfs:isDefinedBy <http://www.radlex.org/RID/RID10321> ;
                                                            rdfs:label "Computed Tomography (CT)" .


