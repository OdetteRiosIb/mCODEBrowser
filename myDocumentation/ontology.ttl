:hasSpecimenIdentifier rdf:type owl:DatatypeProperty ;
                       rdfs:domain <http://snomed.info/id/123038009> ,
                                   :mCR_0000292 ,
                                   :mCR_0000293 ;
                       rdfs:range xsd:string ;
                       rdfs:label "has Specimen Identifier" .


