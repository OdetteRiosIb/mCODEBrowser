                                   rdfs:subClassOf <http://www.radiomics.org/RO/JCNR> ;
                                   rdfs:label "LaplacianFilter" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "Convolutes with a laplacian kernel the original image" .


