###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16809
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16809> rdf:type owl:Class ;
                                                            owl:equivalentClass <http://www.radlex.org/RID/RID10312> ;
                                                            rdfs:subClassOf <http://www.radiomics.org/RO/LK99> ;
                                                            rdfs:comment "Non-invasive method of demonstrating internal anatomy based on the principle that atomic nuclei in a strong magnetic field absorb pulses of radiofrequency energy and emit them as radiowaves which can be reconstructed into computerized images. The concept includes proton spin tomographic techniques." ;
                                                            rdfs:isDefinedBy <http://www.radlex.org/RID/RID10312> ,
                                                                             "http://www.radlex.org/RID/RID10312" ;
                                                            rdfs:label "Magnetic Resonance Image (MRI)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16899
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16899> rdf:type owl:Class ;
