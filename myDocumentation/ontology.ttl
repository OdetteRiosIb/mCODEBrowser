                                   rdfs:subClassOf <http://www.radiomics.org/RO/REK0> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLDM_DependenceCountVariance" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "This feature estimates the variance in dependence counts for the different dependence counts possible" .


###  http://www.radiomics.org/RO/E8JP
<http://www.radiomics.org/RO/E8JP> rdf:type owl:Class ;
                                   rdfs:subClassOf <http://www.radiomics.org/RO/LFYI> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLCM_InverseVariance" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "The inverse variance feature measures how the gray tone differences are distributed in pair elements" .


