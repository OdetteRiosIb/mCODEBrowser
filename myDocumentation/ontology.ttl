                                   rdfs:subClassOf <http://www.radiomics.org/RO/UHIW> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "Maximum" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "The maximum intensity value" .


###  http://www.radiomics.org/RO/9LZ9
