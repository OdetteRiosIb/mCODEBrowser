@prefix : <http://www.semanticweb.org/ontologies/mCODERadiomics#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ontologies/mCODERadiomics#> .

<http://www.semanticweb.org/ontologies/mCODERadiomics> rdf:type owl:Ontology ;
                                                        owl:versionIRI <http://www.semanticweb.org/ontologies/mCODERadiomics/v1.0.0> ;
                                                        owl:imports <http://example.com/snomed_risk_qualifiers.owl> ,
                                                                    <http://ihtsdo.org/snomedct/anatomy> ,
                                                                    <http://ihtsdo.org/snomedct/clinicalFinding> ,
                                                                    <http://local.ontology/loinc_tumor_markers> ,
                                                                    <http://local.ontology/ncit_cancer_staging_method> ,
                                                                    <http://local.ontology/ncit_leukemia_risks> ,
                                                                    <http://local.ontology/ncit_stages_types> ,
                                                                    <http://local.ontology/snomed_AJCC_Staging> ,
                                                                    <http://local.ontology/snomed_anatomy> ,
                                                                    <http://local.ontology/snomed_physical_assessment> ,
                                                                    <http://local.ontology/snomed_social2> ,
                                                                    <http://local.ontology/snomed_specimen> ,
                                                                    <http://local.ontology/snomed_staging> ,
                                                                    <http://local.ontology/snomed_substance> ,
                                                                    <http://local.ontology/snomed_targeted_findings> ,
                                                                    <http://local.ontology/snomed_tumor_size_methods> ,
                                                                    <http://local.ontology/snomed_tumor_staging> ,
                                                                    <http://local.ontology/snomedct_LocationQualifier> ,
                                                                    <http://local.ontology/snomedct_bodylocation2> ,
                                                                    <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl> ,
                                                                    <http://purl.bioontology.org/ontology/LNC/> ,
                                                                    <http://radlex.org/RID/RadLex.owl> ,
                                                                    <http://snomed.info/sct/bodylocation_subset1> ,
                                                                    <http://snomed.info/sct/bodylocation_subset2> ,
                                                                    <http://snomed.info/sct/extracted_tnm_frameworks> ,
                                                                    <http://snomed.info/sct/900000000000207008> ,
                                                                    <http://snomed.info/sct/900000000000207008/version/20240429> ,
                                                                    <http://www.radiomics.org/RO/> ;
                                                        rdfs:comment "This is an ontology extension for Radiomics and Dosiomics. This ontology is embedded in mCODE ontology."@en .

