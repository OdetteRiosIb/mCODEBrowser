                                   rdfs:subClassOf <http://www.radiomics.org/RO/REK0> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLDM_LowDependenceEmphasis" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "This feature emphasises low neighbouring grey level dependence counts" .


