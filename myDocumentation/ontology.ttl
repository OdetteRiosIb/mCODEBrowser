<http://www.radiomics.org/RO/GD3A> rdf:type owl:Class ;
                                   rdfs:subClassOf <http://www.radiomics.org/RO/TP0I> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLRLM_ShortRunHighGreyLevelEmphasis" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "The SRHGLE measures the joint distribution of short runs and high gray level values. The SRHGE is high for the image with many short runs and high gray level values" .


###  http://www.radiomics.org/RO/GU8N
<http://www.radiomics.org/RO/GU8N> rdf:type owl:Class ;
                                   rdfs:subClassOf <http://www.radiomics.org/RO/9SAK> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLSZM_ZoneSizeEntropy" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "Entropy related to the zone sizes" .


