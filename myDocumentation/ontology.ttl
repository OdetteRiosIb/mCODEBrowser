#################################################################

###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasDeathDate
:hasDeathDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :CancerPatient ,
                          :mCR_0000262 ;
              rdfs:range xsd:dateTime ;
              rdfs:label "has Death Date" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasImagingDate
:hasImagingDate rdf:type owl:DatatypeProperty ;
                rdfs:domain <http://www.radiomics.org/RO/LK99> ,
                            :ImagingStudyProfile ;
                rdfs:range xsd:dateTime ;
                rdfs:label "has Imaging Date" .


###  http://www.semanticweb.org/ontologies/mCODERadiomics#hasPatientIdentifier
:hasPatientIdentifier rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CancerPatient ;
                      rdfs:label "has Patient Identifier" .


