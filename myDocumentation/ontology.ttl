###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17007
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17007> rdf:type owl:Class ;
                                                            owl:equivalentClass <http://www.radlex.org/RID/RID10337> ;
                                                            rdfs:subClassOf <http://www.radiomics.org/RO/LK99> ;
                                                            rdfs:comment "An imaging technique using compounds labelled with short-lived positron-emitting radionuclides (such as carbon-11, nitrogen-13, oxygen-15 and fluorine-18) to measure cell metabolism. It has been useful in the study of soft tissues such as cancer; cardiovascular system; and the brain. SPECT is closely related to PET, but uses isotopes with longer half-lives and resolution is lower." ;
                                                            rdfs:isDefinedBy <http://www.radlex.org/RID/RID10337> ,
                                                                             "http://www.radlex.org/RID/RID10337" ;
                                                            rdfs:label "Positron Emission Tomography (PET)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17204
