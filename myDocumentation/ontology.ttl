                                   rdfs:subClassOf <http://www.radiomics.org/RO/LFYI> ;
                                   rdfs:isDefinedBy "IBSI" ;
                                   rdfs:label "GLCM_JointMaximum" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "Probability corresponding to the most common grey level co-occurence in the GCLM" .


