                                   rdfs:subClassOf <http://www.radiomics.org/RO/KA7K> ;
                                   rdfs:label "PixelOperations" ;
                                   <http://www.w3.org/2004/02/skos/core#definition> "This class includes all the filters which apply basic operations on one / multiple pixels of an image" .


